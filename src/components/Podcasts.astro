---
import PodcastsTags from "@/components/PodcastsTags.svelte";
import PodcastsCarousel from "@/components/svelte/PodcastsCarousel.svelte";
import { getCollection } from "astro:content";
import resolveResourceImage from "@/utils/resolveResourceImage";
import { PodcastsThemes } from "@/types/resources";

const markdowns = await getCollection("podcasts");
const podcasts = markdowns.map<any>((markdown) => ({
  ...markdown.data,
  image: resolveResourceImage(markdown.data.image) ?? markdown.data.image,
  slug: markdown.id,
  url: `/resources/podcasts/${markdown.id}`,
}));

const podcastsByTheme = podcasts.reduce<Record<string, any[]>>((acc, p) => {
  (acc[p.theme] ??= []).push(p);
  return acc;
}, {});
---

<section class="py-8 md:py-12">
  <div class="px-4 md:px-8">
    <p class="text-xs font-semibold uppercase tracking-[0.22em] text-primary text-center md:text-start">Resources</p>
    <h2 class="text-5xl text-center md:text-start">Podcasts</h2>
    <p class="mt-2 max-w-4xl text-balance text-center text-muted-foreground md:text-start">
      Podcasts are a great way to improve your English while you're on the go.
      Whether you're commuting, working out, or just relaxing at home, you can
      find a podcast that interests you. Pick topics that pique your interest,
      like self-help, politics, or design. Pro tip: Adjust the playback speed if
      it's too fast and focus on the big picture rather than every single word.
    </p>
  </div>

  <PodcastsTags client:load />

  {Object.values(PodcastsThemes).map((theme) => {
    const items: any[] = podcastsByTheme[theme] ?? [];
    return (
      <div data-podcast-theme={theme} hidden={theme !== PodcastsThemes.Art}>
        {items.length > 0 ? (
          <PodcastsCarousel client:load podcasts={items} />
        ) : (
          <div class="px-3 py-2 pb-10">
            <div class="flex min-h-[420px] items-center justify-center rounded-xl border bg-card p-4 shadow-sm md:min-h-[460px]">
              <p>Coming soon! 🚀</p>
            </div>
          </div>
        )}
      </div>
    );
  })}
</section>

---
import RestLayout from "./RestLayout.astro";
import { Button } from "@/components/ui/button";
import { Card as UiCard } from "@/components/ui/card";
import Footer from "@/sections/Footer.astro";
import Volume from "@/components/Volume.astro";
import { Image } from "astro:assets";
import ImageSkeleton from "@/components/ImageSkeleton.astro";
import cn from "@/utils/cn";
import resolveResourceImage from "@/utils/resolveResourceImage";
import { getCollection } from "astro:content";
import SimilarPodcastsCarousel from "@/components/svelte/SimilarPodcastsCarousel.svelte";

const { frontmatter } = Astro.props;
const { title, longDescription, image, theme, link } = frontmatter;
const slug = Astro.params.slug as string;

const markdowns = await getCollection("podcasts");
const podcasts = markdowns.map<any>((markdown) => ({
  ...markdown.data,
  image: resolveResourceImage(markdown.data.image) ?? markdown.data.image,
  slug: markdown.id,
  url: `/resources/podcasts/${markdown.id}`,
}));

const currentIndex = podcasts.findIndex((pd) => pd.title === title);

const similarPodcasts = podcasts
  .slice(currentIndex + 1)
  .concat(podcasts.slice(0, currentIndex))
  .filter((pd) => pd.theme === theme && pd.title !== title)
  .slice(0, 3);

const resolvedImage = resolveResourceImage(image) ?? image;
---

<script>
  import { selectedPodcast } from "@/components/nanostore";
  import { PodcastsThemes } from "@/types/resources";

  const anchor = document.querySelector("a#anchor-theme");
  anchor?.addEventListener("click", () => {
    const themeText = anchor.textContent;
    const theme = Object.values(PodcastsThemes).find(
      (value) => value === themeText,
    )!;
    selectedPodcast.set(theme);
  });
</script>

<RestLayout title=`English for Abroad - ${title} Podcast`>
  <main class="flex-1">
    <section
      class="mx-auto grid max-w-6xl grid-cols-1 gap-8 px-4 py-8 md:grid-cols-3 md:px-8 md:py-12"
    >
      <h1
        class="mb-4 text-center text-5xl md:col-span-3 md:text-start"
      >
        {title}
      </h1>
      <UiCard class="gap-4 p-4 md:col-span-3 md:grid md:grid-cols-[auto_1fr] md:grid-rows-[auto_auto_1fr_auto] md:gap-x-4">
        <ImageSkeleton
          class="max-h-64 md:col-start-1 md:row-start-1 md:row-span-4 place-self-center mb-4 md:mb-0"
        >
          <Image
            src={resolvedImage}
            alt={title}
            transition:name={slug ? slug : title.replaceAll(" ", "")}
            loading="eager"
            width={256}
            height={256}
          />
        </ImageSkeleton>

        <a
          id="anchor-theme"
          href="/resources"
          class={cn(
            "border border-primary bg-background px-4 py-1 text-xs font-semibold text-primary transition hover:-translate-y-0.5 shadow-xs rounded-full w-fit place-self-end mb-4 row-start-1",
            "md:col-start-2 md:row-start-1 md:mb-0",
          )}
        >
          {theme}
        </a>
        <p class="text-sm font-bold md:col-start-2 md:row-start-2">About:</p>
        <p class="mb-4 text-muted-foreground md:col-start-2 md:row-start-3">
          {longDescription}
        </p>
        <Button
          href={link}
          target="_blank"
          rel="noopener noreferrer"
          variant="secondary"
          size="lg"
          class={cn(
            "w-full rounded-full md:w-fit",
            "md:w-fit md:col-start-2 md:row-start-4",
          )}
          >Listen here <Volume />
        </Button>
      </UiCard>

      <!-- Similar -->
      <h2
        class="text-3xl uppercase text-center md:text-start md:col-span-3"
      >
        Similar podcasts
      </h2>
      <div class="md:col-span-3">
        <SimilarPodcastsCarousel client:load podcasts={similarPodcasts} />
      </div>
    </section>
  </main>

  <Footer />
</RestLayout>

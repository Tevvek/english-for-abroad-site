---
import ImageSkeleton from "@/components/ImageSkeleton.astro";
import Korea from "@/icons/Korea.astro";
import Footer from "@/sections/Footer.astro";
import cn from "@/utils/cn";
import resolveResourceImage from "@/utils/resolveResourceImage";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import RestLayout from "./RestLayout.astro";
import { Button } from "@/components/ui/button";
import { Card as UiCard } from "@/components/ui/card";
import SimilarTvShowsCarousel from "@/components/svelte/SimilarTvShowsCarousel.svelte";

const { frontmatter } = Astro.props;
const { title, longDescription, image, theme, link } = frontmatter;
const slug = Astro.params.slug as string;

const markdowns = await getCollection("tvShows");
const tvShows = markdowns.map<any>((markdown) => ({
  ...markdown.data,
  image: resolveResourceImage(markdown.data.image) ?? markdown.data.image,
  slug: markdown.id,
  url: `/resources/tvshows/${markdown.id}`,
}));

const currentIndex = tvShows.findIndex((pd) => pd.title === title);

const similarTvShows = tvShows
  .slice(currentIndex + 1)
  .concat(tvShows.slice(0, currentIndex))
  .filter((pd) => pd.theme === theme && pd.title !== title)
  .slice(0, 3);

const resolvedImage = resolveResourceImage(image) ?? image;
---

<script>
  import { selectedTvShow } from "@/components/nanostore";
  import { TvShowsThemes } from "@/types/resources";

  const anchor = document.querySelector("a#anchor-theme");
  anchor?.addEventListener("click", () => {
    const themeText = anchor.textContent;
    const theme = Object.values(TvShowsThemes).find(
      (value) => value === themeText,
    )!;
    selectedTvShow.set(theme);
  });
</script>

<RestLayout title=`English for Abroad - ${title} Tv Show`>
  <main class="flex-1">
    <section
      class="mx-auto grid max-w-6xl grid-cols-1 gap-8 px-4 py-8 md:grid-cols-3 md:px-8 md:py-12"
    >
      <h1
        class="mb-4 text-center text-5xl md:col-span-3 md:text-start"
      >
        {title}
      </h1>
      <UiCard class="gap-4 p-4 md:col-span-3 md:grid md:grid-cols-[auto_1fr] md:grid-rows-[auto_auto_1fr_auto] md:gap-x-4">
        <ImageSkeleton
          class="max-h-96 aspect-[2/3] md:col-start-1 md:row-start-1 md:row-span-4 place-self-center mb-4 md:mb-0"
        >
          <Image
            src={resolvedImage}
            alt={title}
            class="h-full object-cover"
            transition:name={slug ? slug : title.replaceAll(" ", "")}
            loading="eager"
            width={256}
            height={384}
          />
        </ImageSkeleton>
        <a
          id="anchor-theme"
          href="/resources"
          class={cn(
            "border border-primary bg-background px-4 py-1 text-xs font-semibold text-primary transition hover:-translate-y-0.5 shadow-xs rounded-full w-fit place-self-end mb-4 row-start-1",
            "md:col-start-2 md:row-start-1 md:mb-0",
          )}
        >
          {theme}
        </a>
        <p class="text-sm font-bold md:col-start-2 md:row-start-2">About:</p>
        <p class="md:col-start-2 md:row-start-3 mb-4 text-muted-foreground">
          {longDescription}
        </p>
        <div
          class="md:col-start-2 md:row-start-4 grid grid-rows-3 grid-cols-1 xl:grid-rows-1 xl:grid-cols-[repeat(3_max-content)] gap-y-2 gap-x-4 place-self-center w-full md:w-fit md:place-self-start"
        >
          <Button
            href={link}
            target="_blank"
            rel="noopener noreferrer"
            variant="secondary"
            size="lg"
            class="w-full rounded-full xl:w-fit"
          >
            <div class="size-5 shrink-0">
              <Korea />
            </div>
            한국에서 시청하기
          </Button>

          <!-- <a
            href={link}
            target="_blank"
            rel="noopener noreferrer"
            class={cn(
              "bg-primary text-white font-bold rounded-full px-12 py-2 transition duration-300 hover:scale-105 shadow flex justify-center items-center gap-x-2"
            )}
          >
            <div class="size-6 rounded-full overflow-hidden">
              <Spain />
            </div>
            Míralo en España
          </a> -->

          <!-- <a
            href={link}
            target="_blank"
            rel="noopener noreferrer"
            class={cn(
              "bg-primary text-white font-bold rounded-full px-12 py-2 transition duration-300 hover:scale-105 shadow flex justify-center items-center gap-x-2"
            )}
          >
            <div class="size-6 rounded-full overflow-hidden">
              <USA />
            </div>
            Watch in the US
          </a> -->
        </div>
      </UiCard>

      <!-- Similar -->
      <h2
        class="text-3xl uppercase text-center md:text-start md:col-span-3"
      >
        Similar TV Shows
      </h2>
      <div class="md:col-span-3">
        <SimilarTvShowsCarousel client:load tvShows={similarTvShows} />
      </div>
    </section>
  </main>

  <Footer />
</RestLayout>

---
import FixedCTA from "@/components/FixedCTA.astro";
import Layout from "./Layout.astro";
import Navbar from "@/components/Navbar.astro";

interface Props {
  title: string;
  showFixedCTA?: boolean;
}

const { title, showFixedCTA = true } = Astro.props;
---

<Layout title={title}>
  <Navbar slot="navbar" />

  {showFixedCTA && <FixedCTA slot="fixed-cta" />}

  <slot />
</Layout>
